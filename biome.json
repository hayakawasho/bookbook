{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "apps/**/*.{ts,tsx}",
      "packages/**/*.{ts,tsx}",
      "!**/dist/**",
      "!**/.wrangler/**",
      "!**/storybook-static/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              { "source": ":NODE:", "type": false },
              ":BLANK_LINE:",
              {
                "source": [":PACKAGE:", ":PACKAGE_WITH_PROTOCOL:", "!@bookbook/**"],
                "type": false
              },
              ":BLANK_LINE:",
              { "source": ["@bookbook/**"], "type": false },
              ":BLANK_LINE:",
              { "source": ["../**", "../*"], "type": false },
              ":BLANK_LINE:",
              { "source": ["./**", "./*"], "type": false },
              ":BLANK_LINE:",
              { "type": false },
              ":BLANK_LINE:",
              { "type": true }
            ]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": false
  }
}

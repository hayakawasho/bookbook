{
  "name": "bookbook",
  "private": true,
  "workspaces": ["apps/web", "apps/bff", "packages/*"],
  "scripts": {
    "dev": "npm run dev -w @bookbook/web",
    "dev:bff": "npm run dev -w @bookbook/bff",
    "build": "npm run build -w @bookbook/web",
    "deploy:bff": "npm run deploy -w @bookbook/bff",
    "preview": "npm run preview -w @bookbook/web",
    "storybook": "npm run storybook -w @bookbook/web",
    "build-storybook": "npm run build-storybook -w @bookbook/web",
    "test": "npm run test -w @bookbook/utils && npm run test -w @bookbook/web && npm run test -w @bookbook/bff",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
